generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  role             Role
  pushSubscription Json?
  createdAt        DateTime  @default(now())

  phone            String?
  timezone         String?
  lastActiveAt     DateTime?
  locale           String?
  referredById     String?
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)

  coachRelations      CoachClientRelation[] @relation("Coach")
  clientRelations     CoachClientRelation[] @relation("Client")
  templates           WorkoutTemplate[]
  templateCategories  TemplateCategory[]
  mobilityMovements   MobilityMovement[]
  mobilityRoutines    MobilityRoutine[]
  assignments         TemplateAssignment[]  @relation("AssignedTo")
  workouts         Workout[]
  comments         Comment[]
  sentMessages     Message[]             @relation("MessageSender")
  receivedMessages Message[]             @relation("MessageReceiver")
  notifications    Notification[]        @relation("NotificationUser")

  clientProfile ClientProfile?
  coachProfile  CoachProfile?

  sentCheckIns     CheckIn[] @relation("CheckInCoach")
  receivedCheckIns CheckIn[] @relation("CheckInClient")

  nutritionPlan     NutritionPlan?
  nutritionMealLogs NutritionMealLog[]

  bodyTrackingPrefs BodyTrackingPreference?
  bodyMetricLogs    BodyMetricLog[]

  recordedVideos  MovementVideo[] @relation("VideoRecorder")
  videoComments   MovementVideoComment[]

  reviewsGiven    Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewCoach")

  coachSessions   Session[] @relation("SessionCoach")
  clientSessions  Session[] @relation("SessionClient")

  coachAvailability       CoachAvailability[]
  availabilityExceptions  AvailabilityException[]

  userAchievements        UserAchievement[]
  personalRecords         PersonalRecord[]
  goalsAsClient           Goal[]              @relation("GoalClient")
  goalsAsCoach            Goal[]              @relation("GoalCoach")

  subscriptionsAsClient   Subscription[]      @relation("SubClient")
  subscriptionsAsCoach    Subscription[]      @relation("SubCoach")

  referralsMade           Referral[]          @relation("Referrer")
  referralsReceived       Referral[]          @relation("Referee")

  mediaAssets             MediaAsset[]
  coachBadges             CoachBadge[]
  messageReactions        MessageReaction[]
}

model ClientProfile {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String    @unique
  age          Int?
  gender       Gender?
  birthDate    DateTime?
  heightCm     Float?
  weightKg     Float?
  goal         String?
  fitnessLevel String?
  updatedAt    DateTime  @updatedAt
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

model CoachProfile {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  bio             String?
  slogan          String?
  accentColor     String?  @default("#F97316")
  transformationPhotos Json?
  specialties     Json?
  experienceYears Int?
  socialMediaUrl  String?
  city            String?
  rating          Decimal? @db.Decimal(3, 1)
  successRate     Int?
  reviewCount     Int?     @default(0)
  updatedAt       DateTime @updatedAt

  videoIntroUrl      String?
  languages          Json?
  certifications     Json?
  education          Json?
  hourlyRate         Float?
  responseTimeHours  Int?
  totalClientsHelped Int?
  beforeAfterStories Json?
  faqs               Json?
  isVerified         Boolean  @default(false)
  isAcceptingClients Boolean  @default(true)

  subscriptionTier   SubscriptionTier @default(FREE)
  subscriptionStatus String?
  inviteCode         String?          @unique
  stripeCustomerId   String?          @unique

  packages CoachPackage[]
}

model CoachPackage {
  id                String       @id @default(cuid())
  profile           CoachProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId         String
  title             String
  description       String?
  price             Float?
  isActive          Boolean      @default(true)
  isPopular         Boolean      @default(false)
  features          String       @default("[]")
  durationWeeks     Int?
  sessionsIncluded  Int?
  maxClients        Int?
  sortOrder         Int          @default(0)
  discount          Float?
  originalPrice     Float?
  recurringInterval String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  subscriptions     Subscription[]
}

enum Role {
  COACH
  CLIENT
}

enum SubscriptionTier {
  FREE
  TIER_1
  TIER_2
  AGENCY
}

model CoachClientRelation {
  id        String         @id @default(cuid())
  coach     User           @relation("Coach", fields: [coachId], references: [id])
  coachId   String
  client    User           @relation("Client", fields: [clientId], references: [id])
  clientId  String
  status    RelationStatus @default(PENDING)
  createdAt DateTime       @default(now())

  notes ClientNotes?

  @@unique([coachId, clientId])
}

enum RelationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Exercise {
  id           String       @id @default(cuid())
  name         String
  type         ExerciseType
  targetMuscle String?
  createdAt    DateTime     @default(now())

  templateExercises WorkoutTemplateExercise[]
  workoutSets       WorkoutSet[]
}

enum ExerciseType {
  WEIGHT
  CARDIO
}

model TemplateCategory {
  id        String   @id @default(cuid())
  coach     User     @relation(fields: [coachId], references: [id])
  coachId   String
  name      String
  color     String   @default("#10b981")
  createdAt DateTime @default(now())

  templates WorkoutTemplate[]
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id])
  coachId     String
  name        String
  description String?
  createdAt   DateTime @default(now())

  category   TemplateCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?

  exercises   WorkoutTemplateExercise[]
  assignments TemplateAssignment[]
  workouts    Workout[]
}

model WorkoutTemplateExercise {
  id         String          @id @default(cuid())
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId String
  order      Int
  groupId    String?
  groupType  String?
  groupOrder Int?
  dropCount  Int?

  targetSets Int?
  targetReps Int?
  targetRir  Int?

  prescribedRestSeconds Int? @default(90)

  durationMinutes Int?
  protocol        Json?
}

model TemplateAssignment {
  id           String          @id @default(cuid())
  template     WorkoutTemplate @relation(fields: [templateId], references: [id])
  templateId   String
  client       User            @relation("AssignedTo", fields: [clientId], references: [id])
  clientId     String
  assignedBy   String
  scheduledFor DateTime        @default(now())
  isOneTime    Boolean         @default(true)
  createdAt    DateTime        @default(now())

  workouts Workout[]
}

model MobilityMovement {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     String
  name        String
  videoUrl    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  routineMovements MobilityRoutineMovement[]

  @@index([coachId, createdAt])
}

model MobilityRoutine {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements MobilityRoutineMovement[]

  @@index([coachId, createdAt])
}

model MobilityRoutineMovement {
  id              String           @id @default(cuid())
  routine         MobilityRoutine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId       String
  movement        MobilityMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  movementId      String
  order           Int
  durationSeconds Int

  @@unique([routineId, order])
  @@index([movementId])
}

model Workout {
  id             String             @id @default(cuid())
  client         User               @relation(fields: [clientId], references: [id])
  clientId       String
  template       WorkoutTemplate    @relation(fields: [templateId], references: [id])
  templateId     String
  assignment     TemplateAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId   String
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?
  status         WorkoutStatus      @default(IN_PROGRESS)
  intensityScore Int?

  notes            String?
  energyLevel      Int?
  moodBefore       Int?
  moodAfter        Int?
  location         String?
  durationSeconds  Int?
  totalVolumeKg    Float?

  sets              WorkoutSet[]
  comments          Comment[]
  movementVideos    MovementVideo[]
  personalRecords   PersonalRecord[]
}

enum WorkoutStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model WorkoutSet {
  id         String   @id @default(cuid())
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId  String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
  setNumber  Int
  groupInstanceId String?
  dropIndex       Int?

  weightKg Float?
  reps     Int?
  rir      Int?

  durationMinutes   Int?
  durationSeconds   Int?
  completed         Boolean @default(false)
  actualRestSeconds Int?
}

model Comment {
  id        String   @id @default(cuid())
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId   String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  reactions   MessageReaction[]
  attachments MessageAttachment[]

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead])
}

model Notification {
  id         String   @id @default(cuid())
  user       User     @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  title      String
  body       String
  type       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  actionUrl  String?
  metadata   Json?
  priority   String?
  expiresAt  DateTime?
  channel    String?

  @@index([userId, isRead, createdAt])
}

model CheckIn {
  id        String   @id @default(cuid())
  coach     User     @relation("CheckInCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  client    User     @relation("CheckInClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  message   String?
  createdAt DateTime @default(now())

  response CheckInResponse?

  @@index([clientId, createdAt])
  @@index([coachId, createdAt])
}

model CheckInResponse {
  id              String   @id @default(cuid())
  checkIn         CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  checkInId       String   @unique
  sleepScore      Int
  stressScore     Int
  motivationScore Int
  notes           String?
  createdAt       DateTime @default(now())
}

enum AdherenceTag {
  GREEN
  YELLOW
  RED
}

model NutritionPlan {
  id       String @id @default(cuid())
  clientId String @unique
  coachId  String

  targetCalories Int?
  targetProtein  Int?
  targetCarbs    Int?
  targetFats     Int?

  dietDocumentUrl String?
  instructions    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model NutritionMealLog {
  id       String @id @default(cuid())
  clientId String

  photoUrl     String?
  adherenceTag AdherenceTag
  clientNote   String?

  aiSummary String?

  loggedAt DateTime @default(now())

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, loggedAt])
}

enum TrackingFrequency {
  OFF
  DAILY
  EVERY_2_DAYS
  EVERY_3_DAYS
  TWICE_A_WEEK
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model BodyTrackingPreference {
  id                   String            @id @default(cuid())
  clientId             String            @unique
  client               User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weightFreq           TrackingFrequency @default(OFF)
  measurementFreq      TrackingFrequency @default(OFF)
  photoFreq            TrackingFrequency @default(OFF)
  activeMeasurements   String            @default("[]")
  updatedAt            DateTime          @updatedAt
}

model BodyMetricLog {
  id            String   @id @default(cuid())
  clientId      String
  client        User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date          DateTime

  weight        Float?

  shoulder      Float?
  chest         Float?
  waist         Float?
  hips          Float?
  arm           Float?
  leg           Float?

  bodyFatPercent  Float?
  muscleMassKg    Float?
  bmiCached       Float?
  sleepHours      Float?
  restingHR       Int?
  hrv             Int?
  visceralFat     Int?
  boneMassKg      Float?
  waterPercent    Float?
  neckMeasurement Float?
  forearm         Float?
  calf            Float?

  frontPhotoUrl String?
  sidePhotoUrl  String?
  backPhotoUrl  String?

  createdAt     DateTime @default(now())

  @@unique([clientId, date])
}

model MovementVideo {
  id              String   @id @default(cuid())
  workoutId       String
  workout         Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  clientId        String
  client          User     @relation(name: "VideoRecorder", fields: [clientId], references: [id], onDelete: Cascade)

  coachId         String   // Coach who will review (derived from client's coach)

  movementId      String   // Movement name/reference
  movementName    String   // Cached for quick display

  videoPath       String   // File path: /uploads/movement-videos/{workoutId}/{clientId}-{movementId}-{timestamp}.webm
  fileSizeBytes   Int
  durationSeconds Int      // Actual recorded duration

  watchedByCoach  Boolean  @default(false)
  watchedAt       DateTime?

  createdAt       DateTime @default(now())

  comments        MovementVideoComment[]

  @@index([coachId, createdAt])
  @@index([clientId, createdAt])
  @@index([workoutId])
}

model MovementVideoComment {
  id              String   @id @default(cuid())
  videoId         String
  video           MovementVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  coachId         String
  coach           User     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  content         String   @db.Text // max 2000 chars

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([videoId, createdAt])
  @@index([coachId, createdAt])
}

model Review {
  id                String   @id @default(cuid())
  coach             User     @relation("ReviewCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId           String
  client            User     @relation("ReviewAuthor", fields: [clientId], references: [id], onDelete: Cascade)
  clientId          String
  rating            Float
  title             String?
  content           String
  isAnon            Boolean  @default(false)
  createdAt         DateTime @default(now())

  helpfulCount      Int      @default(0)
  coachReply        String?
  coachReplyAt      DateTime?
  verifiedPurchase  Boolean  @default(false)
  photos            Json?
  durationWithCoach Int?

  @@unique([coachId, clientId])
  @@index([coachId, createdAt])
}

model CoachAvailability {
  id        String @id @default(cuid())
  coach     User   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  dayOfWeek Int    // 0=Monday, 6=Sunday
  startTime String // HH:mm
  endTime   String // HH:mm

  @@unique([coachId, dayOfWeek])
}

model Session {
  id           String        @id @default(cuid())
  coach        User          @relation("SessionCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId      String
  client       User          @relation("SessionClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  scheduledFor DateTime
  duration     Int           @default(60)
  type         String        @default("consultation")
  status       SessionStatus @default(SCHEDULED)
  notes        String?
  createdAt    DateTime      @default(now())

  meetingUrl       String?
  recordingUrl     String?
  agenda           String?
  summary          String?
  clientFeedback   String?
  rating           Int?
  reminderSentAt   DateTime?
  isPaid           Boolean   @default(false)

  @@index([coachId, scheduledFor])
  @@index([clientId, scheduledFor])
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model ClientNotes {
  id         String              @id @default(cuid())
  relation   CoachClientRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
  relationId String              @unique
  notes      String              @default("")
  tags       String              @default("[]")
  updatedAt  DateTime            @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  iconUrl     String?
  category    String
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  unlocks UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model PersonalRecord {
  id             String   @id @default(cuid())
  client         User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  exerciseId     String
  weightKg       Float
  reps           Int
  estimatedOneRM Float?
  workout        Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  workoutId      String?
  achievedAt     DateTime @default(now())

  @@index([clientId, exerciseId])
  @@index([clientId, achievedAt])
}

model Subscription {
  id                   String        @id @default(cuid())
  client               User          @relation("SubClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId             String
  coach                User          @relation("SubCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId              String
  package              CoachPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  packageId            String?
  status               String
  startedAt            DateTime      @default(now())
  expiresAt            DateTime?
  cancelAtPeriodEnd    Boolean       @default(false)
  stripeSubscriptionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  payments Payment[]

  @@index([clientId, status])
  @@index([coachId, status])
}

model Payment {
  id             String        @id @default(cuid())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionId String?
  amount         Float
  currency       String        @default("TRY")
  status         String
  provider       String
  providerRef    String?
  invoiceUrl     String?
  createdAt      DateTime      @default(now())

  @@index([subscriptionId])
}

model Goal {
  id           String     @id @default(cuid())
  client       User       @relation("GoalClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  coach        User?      @relation("GoalCoach", fields: [coachId], references: [id], onDelete: SetNull)
  coachId      String?
  title        String
  type         String
  targetValue  Float?
  currentValue Float?
  unit         String?
  targetDate   DateTime?
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  milestones Milestone[]

  @@index([clientId, status])
}

model Milestone {
  id         String    @id @default(cuid())
  goal       Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalId     String
  title      String
  achievedAt DateTime?
  order      Int       @default(0)

  @@index([goalId, order])
}

model Referral {
  id         String   @id @default(cuid())
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId String
  referee    User?    @relation("Referee", fields: [refereeId], references: [id], onDelete: SetNull)
  refereeId  String?
  code       String   @unique
  bonusType  String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([referrerId, status])
}

model AvailabilityException {
  id        String   @id @default(cuid())
  coach     User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  date      DateTime
  isClosed  Boolean  @default(true)
  startTime String?
  endTime   String?

  @@unique([coachId, date])
  @@index([coachId, date])
}

model MediaAsset {
  id           String   @id @default(cuid())
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  type         String
  url          String
  mimeType     String
  sizeBytes    Int
  thumbnailUrl String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([ownerId, type, createdAt])
}

model CoachBadge {
  id        String   @id @default(cuid())
  coach     User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  code      String
  awardedAt DateTime @default(now())

  @@unique([coachId, code])
}

model AnalyticsSnapshot {
  id      String   @id @default(cuid())
  scope   String
  scopeId String
  date    DateTime @db.Date
  metrics Json

  @@unique([scope, scopeId, date])
  @@index([scopeId, date])
}

model MessageReaction {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  url       String
  type      String
  sizeBytes Int
  createdAt DateTime @default(now())

  @@index([messageId])
}
