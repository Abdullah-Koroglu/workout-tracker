generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  role             Role
  pushSubscription Json?
  createdAt        DateTime @default(now())

  coachRelations      CoachClientRelation[] @relation("Coach")
  clientRelations     CoachClientRelation[] @relation("Client")
  templates           WorkoutTemplate[]
  templateCategories  TemplateCategory[]
  mobilityMovements   MobilityMovement[]
  mobilityRoutines    MobilityRoutine[]
  assignments         TemplateAssignment[]  @relation("AssignedTo")
  workouts         Workout[]
  comments         Comment[]
  sentMessages     Message[]             @relation("MessageSender")
  receivedMessages Message[]             @relation("MessageReceiver")
  notifications    Notification[]        @relation("NotificationUser")

  clientProfile ClientProfile?
  coachProfile  CoachProfile?

  sentCheckIns     CheckIn[] @relation("CheckInCoach")
  receivedCheckIns CheckIn[] @relation("CheckInClient")

  nutritionPlan     NutritionPlan?
  nutritionMealLogs NutritionMealLog[]

  bodyTrackingPrefs BodyTrackingPreference?
  bodyMetricLogs    BodyMetricLog[]

  recordedVideos  MovementVideo[] @relation("VideoRecorder")
  videoComments   MovementVideoComment[]

  reviewsGiven    Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewCoach")

  coachSessions   Session[] @relation("SessionCoach")
  clientSessions  Session[] @relation("SessionClient")

  coachAvailability CoachAvailability[]
}

model ClientProfile {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String    @unique
  age          Int?
  gender       Gender?
  birthDate    DateTime?
  heightCm     Float?
  weightKg     Float?
  goal         String?
  fitnessLevel String?
  updatedAt    DateTime  @updatedAt
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

model CoachProfile {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  bio             String?
  slogan          String?
  accentColor     String?  @default("#F97316")
  transformationPhotos Json?
  specialties     Json?
  experienceYears Int?
  socialMediaUrl  String?
  city            String?
  rating          Decimal? @db.Decimal(3, 1)
  successRate     Int?
  reviewCount     Int?     @default(0)
  updatedAt       DateTime @updatedAt

  subscriptionTier   SubscriptionTier @default(FREE)
  subscriptionStatus String?
  inviteCode         String?          @unique
  stripeCustomerId   String?          @unique

  packages CoachPackage[]
}

model CoachPackage {
  id          String       @id @default(cuid())
  profile     CoachProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String
  title       String
  description String?
  price       Float?
  isActive    Boolean      @default(true)
  isPopular   Boolean      @default(false)
  features    String       @default("[]") // JSON array of feature strings
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum Role {
  COACH
  CLIENT
}

enum SubscriptionTier {
  FREE
  TIER_1
  TIER_2
  AGENCY
}

model CoachClientRelation {
  id        String         @id @default(cuid())
  coach     User           @relation("Coach", fields: [coachId], references: [id])
  coachId   String
  client    User           @relation("Client", fields: [clientId], references: [id])
  clientId  String
  status    RelationStatus @default(PENDING)
  createdAt DateTime       @default(now())

  notes ClientNotes?

  @@unique([coachId, clientId])
}

enum RelationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Exercise {
  id           String       @id @default(cuid())
  name         String
  type         ExerciseType
  targetMuscle String?
  createdAt    DateTime     @default(now())

  templateExercises WorkoutTemplateExercise[]
  workoutSets       WorkoutSet[]
}

enum ExerciseType {
  WEIGHT
  CARDIO
}

model TemplateCategory {
  id        String   @id @default(cuid())
  coach     User     @relation(fields: [coachId], references: [id])
  coachId   String
  name      String
  color     String   @default("#10b981")
  createdAt DateTime @default(now())

  templates WorkoutTemplate[]
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id])
  coachId     String
  name        String
  description String?
  createdAt   DateTime @default(now())

  category   TemplateCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?

  exercises   WorkoutTemplateExercise[]
  assignments TemplateAssignment[]
  workouts    Workout[]
}

model WorkoutTemplateExercise {
  id         String          @id @default(cuid())
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId String
  order      Int

  targetSets Int?
  targetReps Int?
  targetRir  Int?

  prescribedRestSeconds Int? @default(90)

  durationMinutes Int?
  protocol        Json?
}

model TemplateAssignment {
  id           String          @id @default(cuid())
  template     WorkoutTemplate @relation(fields: [templateId], references: [id])
  templateId   String
  client       User            @relation("AssignedTo", fields: [clientId], references: [id])
  clientId     String
  assignedBy   String
  scheduledFor DateTime        @default(now())
  isOneTime    Boolean         @default(true)
  createdAt    DateTime        @default(now())

  workouts Workout[]
}

model MobilityMovement {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     String
  name        String
  videoUrl    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  routineMovements MobilityRoutineMovement[]

  @@index([coachId, createdAt])
}

model MobilityRoutine {
  id          String   @id @default(cuid())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements MobilityRoutineMovement[]

  @@index([coachId, createdAt])
}

model MobilityRoutineMovement {
  id              String           @id @default(cuid())
  routine         MobilityRoutine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId       String
  movement        MobilityMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  movementId      String
  order           Int
  durationSeconds Int

  @@unique([routineId, order])
  @@index([movementId])
}

model Workout {
  id             String             @id @default(cuid())
  client         User               @relation(fields: [clientId], references: [id])
  clientId       String
  template       WorkoutTemplate    @relation(fields: [templateId], references: [id])
  templateId     String
  assignment     TemplateAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId   String
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?
  status         WorkoutStatus      @default(IN_PROGRESS)
  intensityScore Int?

  sets              WorkoutSet[]
  comments          Comment[]
  movementVideos    MovementVideo[]
}

enum WorkoutStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model WorkoutSet {
  id         String   @id @default(cuid())
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId  String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
  setNumber  Int

  weightKg Float?
  reps     Int?
  rir      Int?

  durationMinutes   Int?
  durationSeconds   Int?
  completed         Boolean @default(false)
  actualRestSeconds Int?
}

model Comment {
  id        String   @id @default(cuid())
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId   String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model CheckIn {
  id        String   @id @default(cuid())
  coach     User     @relation("CheckInCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  client    User     @relation("CheckInClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  message   String?
  createdAt DateTime @default(now())

  response CheckInResponse?

  @@index([clientId, createdAt])
  @@index([coachId, createdAt])
}

model CheckInResponse {
  id              String   @id @default(cuid())
  checkIn         CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  checkInId       String   @unique
  sleepScore      Int
  stressScore     Int
  motivationScore Int
  notes           String?
  createdAt       DateTime @default(now())
}

enum AdherenceTag {
  GREEN
  YELLOW
  RED
}

model NutritionPlan {
  id       String @id @default(cuid())
  clientId String @unique
  coachId  String

  targetCalories Int?
  targetProtein  Int?
  targetCarbs    Int?
  targetFats     Int?

  dietDocumentUrl String?
  instructions    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model NutritionMealLog {
  id       String @id @default(cuid())
  clientId String

  photoUrl     String?
  adherenceTag AdherenceTag
  clientNote   String?

  aiSummary String?

  loggedAt DateTime @default(now())

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, loggedAt])
}

enum TrackingFrequency {
  OFF
  DAILY
  EVERY_2_DAYS
  EVERY_3_DAYS
  TWICE_A_WEEK
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model BodyTrackingPreference {
  id                   String            @id @default(cuid())
  clientId             String            @unique
  client               User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weightFreq           TrackingFrequency @default(OFF)
  measurementFreq      TrackingFrequency @default(OFF)
  photoFreq            TrackingFrequency @default(OFF)
  activeMeasurements   String            @default("[]")
  updatedAt            DateTime          @updatedAt
}

model BodyMetricLog {
  id            String   @id @default(cuid())
  clientId      String
  client        User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date          DateTime

  weight        Float?

  shoulder      Float?
  chest         Float?
  waist         Float?
  hips          Float?
  arm           Float?
  leg           Float?

  frontPhotoUrl String?
  sidePhotoUrl  String?
  backPhotoUrl  String?

  createdAt     DateTime @default(now())

  @@unique([clientId, date])
}

model MovementVideo {
  id              String   @id @default(cuid())
  workoutId       String
  workout         Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  clientId        String
  client          User     @relation(name: "VideoRecorder", fields: [clientId], references: [id], onDelete: Cascade)

  coachId         String   // Coach who will review (derived from client's coach)

  movementId      String   // Movement name/reference
  movementName    String   // Cached for quick display

  videoPath       String   // File path: /uploads/movement-videos/{workoutId}/{clientId}-{movementId}-{timestamp}.webm
  fileSizeBytes   Int
  durationSeconds Int      // Actual recorded duration

  watchedByCoach  Boolean  @default(false)
  watchedAt       DateTime?

  createdAt       DateTime @default(now())

  comments        MovementVideoComment[]

  @@index([coachId, createdAt])
  @@index([clientId, createdAt])
  @@index([workoutId])
}

model MovementVideoComment {
  id              String   @id @default(cuid())
  videoId         String
  video           MovementVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  coachId         String
  coach           User     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  content         String   @db.Text // max 2000 chars

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([videoId, createdAt])
  @@index([coachId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  coach     User     @relation("ReviewCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  client    User     @relation("ReviewAuthor", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  rating    Float    // 1-5
  title     String?
  content   String
  isAnon    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([coachId, clientId])
  @@index([coachId, createdAt])
}

model CoachAvailability {
  id        String @id @default(cuid())
  coach     User   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId   String
  dayOfWeek Int    // 0=Monday, 6=Sunday
  startTime String // HH:mm
  endTime   String // HH:mm

  @@unique([coachId, dayOfWeek])
}

model Session {
  id           String        @id @default(cuid())
  coach        User          @relation("SessionCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachId      String
  client       User          @relation("SessionClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  scheduledFor DateTime
  duration     Int           @default(60) // minutes
  type         String        @default("consultation") // consultation, follow_up, check_in
  status       SessionStatus @default(SCHEDULED)
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([coachId, scheduledFor])
  @@index([clientId, scheduledFor])
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model ClientNotes {
  id         String              @id @default(cuid())
  relation   CoachClientRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
  relationId String              @unique
  notes      String              @default("")
  tags       String              @default("[]") // JSON array of tag strings
  updatedAt  DateTime            @updatedAt
}
