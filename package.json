{
  "name": "fitcoach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:ws\"",
    "dev:next": "next dev",
    "dev:ws": "node server.js",
    "build": "next build",
    "prestart": "prisma generate",
    "start": "next start",
    "start:ws": "node server.js",
    "start:ws:local": "node --env-file=.env server.js",
    "start:next": "next start",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate:sqlite-to-postgres": "SQLITE_PG_RUN_MODE=direct python3 prisma/sqlite_to_postgres.py",
    "db:studio": "prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
